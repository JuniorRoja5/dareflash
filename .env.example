# =============================================================================
# DareFlash — plantilla de variables de entorno
# -----------------------------------------------------------------------------
# COPIA este archivo a `.env` y rellena los valores. `.env` NUNCA se commitea.
# En produccion las variables viven en hPanel (Hostinger), no en el repo.
# Claves unicas por entorno; rotar si se filtran.
# =============================================================================

# App
NODE_ENV=development
APP_URL=http://localhost:3000

# Base de datos (MySQL)
# El `connection_limit` debe ajustarse al limite del plan compartido (PENDIENTE hPanel).
# En LOCAL, estos valores coinciden con docker-compose.dev.yml (puerto 3307 en el host).
DATABASE_URL="mysql://dareflash:dareflash_dev@127.0.0.1:3307/dareflash?connection_limit=5"

# Auth
AUTH_SECRET=                 # openssl rand -base64 32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Bunny.net
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_CDN_HOSTNAME=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (transaccional)
EMAIL_FROM=
EMAIL_API_KEY=

# Cola de trabajos
CRON_SECRET=                 # openssl rand -base64 32

# Observabilidad
SENTRY_DSN=
